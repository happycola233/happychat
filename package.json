{
  "name": "happychat",
  "version": "1.0.0",
  "description": "私有 AI 聊天站，基于 Vite + React + Hono + SQLite + Responses API",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx src/server/index.ts",
    "dev:server:watch": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "start": "node dist/server/index.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:local": "tsx scripts/local-smoke.ts",
    "smoke:upstream": "tsx scripts/upstream-smoke.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happycola233/happychat.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/happycola233/happychat/issues"
  },
  "homepage": "https://github.com/happycola233/happychat#readme",
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@tanstack/react-query": "^5.101.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "eventsource-parser": "^3.1.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.25",
    "katex": "^0.17.0",
    "lucide-react": "^1.18.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
