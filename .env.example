# 应用服务
HOST=127.0.0.1
PORT=8787
CLIENT_ORIGIN=http://127.0.0.1:5173

# 第一次启动可留空，服务端会在 data/.generated-env 中给出随机值提示。
APP_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=change-me-32-byte-random-key

# 数据与上传目录
DATABASE_PATH=./data/happychat.sqlite
UPLOAD_DIR=./data/uploads

# 真实上游冒烟测试使用，不会被前端读取
SMOKE_BASE_URL=https://api.example.com/v1
SMOKE_API_KEY=
