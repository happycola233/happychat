{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@shared/*": ["../shared/*"]
    },
    "noEmit": true
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx", "../shared/**/*.ts"]
}
