# 后端端口
PORT=8787
# 数据与上传文件目录
DATA_DIR=./data
# SQLite 路径（drizzle-kit 也会读取）
DATABASE_URL=./data/happychat.db
# 会话签名密钥（生产必须设置为高强度随机值）
SESSION_SECRET=
# Provider API Key 落库加密密钥（生产必须设置）
APP_ENCRYPTION_KEY=
# 可选：运行 `npm run db:seed` 时会据此幂等地预置一个上游 Provider 并同步模型，方便部署后开箱即用。
# 不设置则跳过（仍可在管理后台手动添加 Provider）。请勿把真实密钥提交到仓库。
UPSTREAM_BASE_URL=https://api.example.com/v1
UPSTREAM_API_KEY=
