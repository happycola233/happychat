{
  "name": "happychat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "cross-env NODE_ENV=development node --watch --watch-preserve-output --import tsx server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:web",
    "build:web": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "typecheck": "npm run typecheck:server && npm run typecheck:web",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "typecheck:web": "tsc --noEmit -p web/tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "@tanstack/react-query": "^5.101.0",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "emojibase-data": "^17.0.0",
    "frimousse": "^0.3.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.25",
    "katex": "^0.17.0",
    "lucide-react": "^1.20.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-colorful": "^5.7.0",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.2.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-cjk-friendly": "^2.3.1",
    "remark-cjk-friendly-gfm-strikethrough": "^2.3.1",
    "remark-flexible-markers": "^1.3.5",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
